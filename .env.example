# Copy this file to .env and replace the placeholders with your Cliniko details.
CLINIKO_API_KEY=replace-with-your-cliniko-api-key
CLINIKO_API_BASE_URL=https://api.<your-shard>.cliniko.com/v1
CLINIKO_USER_AGENT=Voice AI Clinic Receptionist (your-email@example.com)
CLINIKO_TIMEOUT_SECONDS=10

# Retell API key used only to verify X-Retell-Signature on /retell/* routes.
RETELL_API_KEY=replace-with-your-retell-api-key
